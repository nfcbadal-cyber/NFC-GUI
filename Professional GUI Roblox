    dropdownBtn.Name = "DropdownButton"
    dropdownBtn.Size = UDim2.new(0.5, -10, 0, 30)
    dropdownBtn.Position = UDim2.new(0.5, 10, 0.5, -15)
    dropdownBtn.BackgroundColor3 = Theme.Tertiary
    dropdownBtn.BorderSizePixel = 0
    dropdownBtn.Parent = container
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = dropdownBtn
    
    -- Selected value text
    local selectedText = Instance.new("TextLabel")
    selectedText.Size = UDim2.new(1, -30, 1, 0)
    selectedText.Position = UDim2.new(0, 10, 0, 0)
    selectedText.BackgroundTransparency = 1
    selectedText.Text = config.Default or (config.Options and config.Options[1]) or "Select"
    selectedText.TextColor3 = Theme.Text
    selectedText.TextXAlignment = Enum.TextXAlignment.Left
    selectedText.Font = Enum.Font.Gotham
    selectedText.TextSize = 14
    selectedText.Parent = dropdownBtn
    
    -- Arrow icon
    local arrow = Instance.new("ImageLabel")
    arrow.Size = UDim2.new(0, 16, 0, 16)
    arrow.Position = UDim2.new(1, -26, 0.5, -8)
    arrow.BackgroundTransparency = 1
    arrow.Image = "rbxassetid://6023426926"
    arrow.ImageColor3 = Theme.Text
    arrow.Parent = dropdownBtn
    
    -- Dropdown list
    local listFrame = Instance.new("Frame")
    listFrame.Name = "DropdownList"
    listFrame.Size = UDim2.new(0.5, -10, 0, 0)
    listFrame.Position = UDim2.new(0.5, 10, 0, 45)
    listFrame.BackgroundColor3 = Theme.Secondary
    listFrame.BorderSizePixel = 0
    listFrame.ClipsDescendants = true
    listFrame.Visible = false
    listFrame.Parent = container
    
    local listCorner = Instance.new("UICorner")
    listCorner.CornerRadius = UDim.new(0, 6)
    listCorner.Parent = listFrame
    
    local listLayout = Instance.new("UIListLayout")
    listLayout.Parent = listFrame
    listLayout.Padding = UDim.new(0, 2)
    
    local listPadding = Instance.new("UIPadding")
    listPadding.Parent = listFrame
    listPadding.PaddingTop = UDim.new(0, 4)
    listPadding.PaddingBottom = UDim.new(0, 4)
    
    -- Populate options
    local options = config.Options or {}
    local callback = config.Callback or function() end
    
    for i, opt in ipairs(options) do
        local optBtn = Instance.new("TextButton")
        optBtn.Name = "Option"..i
        optBtn.Size = UDim2.new(1, -8, 0, 30)
        optBtn.Position = UDim2.new(0, 4, 0, 4 + (i-1)*32)
        optBtn.BackgroundTransparency = 1
        optBtn.Text = opt
        optBtn.TextColor3 = Theme.Text
        optBtn.Font = Enum.Font.Gotham
        optBtn.TextSize = 14
        optBtn.Parent = listFrame
        
        optBtn.MouseEnter:Connect(function()
            smoothTween(optBtn, {TextColor3 = Theme.Accent}, 0.1)
        end)
        optBtn.MouseLeave:Connect(function()
            smoothTween(optBtn, {TextColor3 = Theme.Text}, 0.1)
        end)
        
        optBtn.MouseButton1Click:Connect(function()
            selectedText.Text = opt
            callback(opt)
            
            smoothTween(listFrame, {Size = UDim2.new(0.5, -10, 0, 0)}, 0.15)
            task.wait(0.15)
            listFrame.Visible = false
            arrow.Image = "rbxassetid://6023426926"
        end)
    end
    
    local listHeight = #options * 32 + 8
    listFrame.Size = UDim2.new(0.5, -10, 0, 0)
    
    -- Toggle dropdown
    local isOpen = false
    dropdownBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            isOpen = not isOpen
            
            if isOpen then
                listFrame.Visible = true
                smoothTween(listFrame, {Size = UDim2.new(0.5, -10, 0, listHeight)}, 0.2)
                arrow.Image = "rbxassetid://6023426925"
            else
                smoothTween(listFrame, {Size = UDim2.new(0.5, -10, 0, 0)}, 0.15)
                task.wait(0.15)
                listFrame.Visible = false
                arrow.Image = "rbxassetid://6023426926"
            end
        end
    end)
    
    return {
        Set = function(_, option)
            selectedText.Text = option
        end,
        Get = function() return selectedText.Text end
    }
end

