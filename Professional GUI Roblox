    iconFrame.Name = "MinimizedIcon"
    iconFrame.Size = UDim2.new(0, 18, 0, 18)
    iconFrame.Position = UDim2.new(0, 50, 0, 50)
    iconFrame.BackgroundColor3 = Theme.Accent
    iconFrame.BackgroundTransparency = 0.2
    iconFrame.BorderSizePixel = 0
    iconFrame.Visible = false
    iconFrame.Parent = guiHolder
    iconFrame.ZIndex = 1000
    
    local iconCorner = Instance.new("UICorner")
    iconCorner.CornerRadius = UDim.new(0, 6)
    iconCorner.Parent = iconFrame
    
    local iconStroke = Instance.new("UIStroke")
    iconStroke.Color = Theme.Text
    iconStroke.Thickness = 1
    iconStroke.Transparency = 0.5
    iconStroke.Parent = iconFrame
    
    local iconImage = Instance.new("ImageLabel")
    iconImage.Name = "IconImage"
    iconImage.Size = UDim2.new(1, -4, 1, -4)
    iconImage.Position = UDim2.new(0, 2, 0, 2)
    iconImage.BackgroundTransparency = 1
    iconImage.Image = "rbxassetid://6023426920"
    iconImage.ImageColor3 = Theme.Text
    iconImage.Parent = iconFrame
    
    -- Pulse animation for icon
    local function pulseIcon()
        local tweenInfo = TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
        local goal = {Size = UDim2.new(0, 22, 0, 22)}
        TweenService:Create(iconFrame, tweenInfo, goal):Play()
    end
    
    -- Make icon draggable
    makeDraggable(iconFrame, iconFrame)
    
    -- Window state
    local isMinimized = false
    
    -- Minimize function
    local function minimize()
        if isMinimized then return end
        isMinimized = true
        
        local hideTween = smoothTween(mainFrame, {
            Size = UDim2.new(0, 0, 0, 0),
            Position = UDim2.new(0.5, 0, 0.5, 0)
        }, 0.3)
        
        hideTween.Completed:Connect(function()
            mainFrame.Visible = false
            
            local absPos = mainFrame.AbsolutePosition
            iconFrame.Position = UDim2.new(0, absPos.X, 0, absPos.Y)
            iconFrame.Visible = true
            
            smoothTween(iconFrame, {
                Size = UDim2.new(0, 18, 0, 18)
            }, 0.2)
            
            pulseIcon()
        end)
    end
    
    -- Maximize function
    local function maximize()
        if not isMinimized then return end
        isMinimized = false
        
        local allTweens = TweenService:GetDecorators(iconFrame)
        if allTweens then
            for _, tween in pairs(allTweens) do
                pcall(function() tween:Cancel() end)
            end
        end
        
        local iconPos = iconFrame.AbsolutePosition
        
        iconFrame.Visible = false
        
        mainFrame.Position = UDim2.new(0, iconPos.X, 0, iconPos.Y)
        mainFrame.Size = UDim2.new(0, 18, 0, 18)
        mainFrame.Visible = true
        
        smoothTween(mainFrame, {
            Size = UDim2.new(0, windowWidth, 0, windowHeight),
            Position = UDim2.new(0.5, -windowWidth/2, 0.5, -windowHeight/2)
        }, 0.3)
    end
    
    -- Toggle function
    local function toggle()
        if isMinimized then
            maximize()
        else
            minimize()
        end
    end
    
    -- Connect buttons
    minimizeBtn.MouseButton1Click:Connect(minimize)
    
    iconFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            maximize()
        end
    end)
    
    closeBtn.MouseButton1Click:Connect(function()
        mainFrame:Destroy()
        iconFrame:Destroy()
    end)
    
    -- ================================================================
    -- WINDOW OBJECT
    -- ================================================================
    
    local windowObj = {
        Frame = mainFrame,
        Icon = iconFrame,
        Toggle = toggle,
        Minimize = minimize,
        Maximize = maximize,
        tabs = {},
        currentTab = nil
    }
    
    -- ================================================================
    -- TAB CREATION
    -- ================================================================
    
    function windowObj:CreateTab(name, iconAsset)
        local tabButton = Instance.new("TextButton")
        tabButton.Name = name.."Tab"
        tabButton.Size = UDim2.new(1, -10, 0, 35)
        tabButton.Position = UDim2.new(0, 5, 0, 5 + (#windowObj.tabs * 40))
        tabButton.BackgroundColor3 = Theme.Background
        tabButton.BackgroundTransparency = 0.5
        tabButton.Text = ""
        tabButton.BorderSizePixel = 0
        tabButton.Parent = tabBar
        
        local tabCorner = Instance.new("UICorner")
        tabCorner.CornerRadius = UDim.new(0, 6)
        tabCorner.Parent = tabButton
        
        -- Tab icon
        if iconAsset then
            local icon = Instance.new("ImageLabel")
            icon.Size = UDim2.new(0, 20, 0, 20)
            icon.Position = UDim2.new(0, 8, 0.5, -10)
            icon.BackgroundTransparency = 1
            icon.Image = iconAsset
            icon.ImageColor3 = Theme.Text
            icon.Parent = tabButton
        end
        
        -- Tab label
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, -30, 1, 0)
        label.Position = UDim2.new(0, 30, 0, 0)
        label.BackgroundTransparency = 1
        label.Text = name
        label.TextColor3 = Theme.Text
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Font = Enum.Font.Gotham
        label.TextSize = 14
        label.Parent = tabButton
        
        tabBar.CanvasSize = UDim2.new(0, 0, 0, 10 + (#windowObj.tabs + 1) * 40)
        
        -- Create page
        local page = Instance.new("ScrollingFrame")
        page.Name = name.."Page"
        page.Size = UDim2.new(1, 0, 1, 0)
        page.BackgroundTransparency = 1
        page.BorderSizePixel = 0
        page.ScrollBarThickness = 6
        page.ScrollBarImageColor3 = Theme.Accent
        page.AutomaticCanvasSize = Enum.AutomaticSize.Y
        page.Visible = false
        page.Parent = pageContainer
        
        -- Tab selection
        tabButton.MouseButton1Click:Connect(function()
            for _, p in ipairs(pageContainer:GetChildren()) do
                if p:IsA("ScrollingFrame") then
                    p.Visible = false
                end
            end
            
            page.Visible = true
            
            for _, btn in ipairs(tabBar:GetChildren()) do
                if btn:IsA("TextButton") then
                    smoothTween(btn, {BackgroundColor3 = Theme.Background}, 0.1)
                end
            end
            smoothTween(tabButton, {BackgroundColor3 = Theme.Accent}, 0.1)
        end)
        
        table.insert(windowObj.tabs, {Button = tabButton, Page = page})
        
        if #windowObj.tabs == 1 then
            tabButton.MouseButton1Click:Fire()
        end
        
        return page
    end
    
    return windowObj
end

