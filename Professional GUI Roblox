    label.TextColor3 = Theme.Text
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    label.TextSize = 16
    label.Parent = container
    
    local valueLabel = Instance.new("TextLabel")
    valueLabel.Size = UDim2.new(0.5, -10, 0, 20)
    valueLabel.Position = UDim2.new(0.5, 10, 0, 0)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Text = tostring(config.Default or config.Min or 0)
    valueLabel.TextColor3 = Theme.Accent
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.TextSize = 16
    valueLabel.Parent = container
    
    -- Slider track
    local track = Instance.new("Frame")
    track.Name = "SliderTrack"
    track.Size = UDim2.new(1, 0, 0, 6)
    track.Position = UDim2.new(0, 0, 0, 30)
    track.BackgroundColor3 = Theme.Tertiary
    track.BorderSizePixel = 0
    track.Parent = container
    
    local trackCorner = Instance.new("UICorner")
    trackCorner.CornerRadius = UDim.new(1, 0)
    trackCorner.Parent = track
    
    -- Slider fill
    local fill = Instance.new("Frame")
    fill.Name = "SliderFill"
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BackgroundColor3 = Theme.Accent
    fill.BorderSizePixel = 0
    fill.Parent = track
    
    local fillCorner = Instance.new("UICorner")
    fillCorner.CornerRadius = UDim.new(1, 0)
    fillCorner.Parent = fill
    
    -- Slider knob
    local knob = Instance.new("Frame")
    knob.Name = "SliderKnob"
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.Position = UDim2.new(0, -8, 0.5, -8)
    knob.BackgroundColor3 = Theme.Text
    knob.BorderSizePixel = 0
    knob.ZIndex = 2
    knob.Parent = fill
    
    local knobCorner = Instance.new("UICorner")
    knobCorner.CornerRadius = UDim.new(1, 0)
    knobCorner.Parent = knob
    
    local min = config.Min or 0
    local max = config.Max or 100
    local value = config.Default or min
    local callback = config.Callback or function() end
    local increment = config.Increment or 1
    
    local function updateValue(newValue, fromDrag)
        value = math.clamp(newValue, min, max)
        if increment > 0 then
            value = math.round(value / increment) * increment
        end
        
        local percent = (value - min) / (max - min)
        fill.Size = UDim2.new(percent, 0, 1, 0)
        
        valueLabel.Text = tostring(value)
        
        if not fromDrag then
            callback(value)
        end
    end
    
    updateValue(value, true)
    
    -- Drag functionality
    local dragging = false
    
    knob.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            
            smoothTween(knob, {Size = UDim2.new(0, 20, 0, 20)}, 0.1)
            
            local connection
            connection = UserInputService.InputChanged:Connect(function()
                if not dragging then connection:Disconnect() return end
                
                local mousePos = Mouse.X
                local trackPos = track.AbsolutePosition.X
                local trackSize = track.AbsoluteSize.X
                
                local relativeX = math.clamp(mousePos - trackPos, 0, trackSize)
                local percent = relativeX / trackSize
                local newValue = min + (max - min) * percent
                
                updateValue(newValue, true)
            end)
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                    smoothTween(knob, {Size = UDim2.new(0, 16, 0, 16)}, 0.1)
                    callback(value)
                end
            end)
        end
    end)
    
    return {
        Set = function(_, newValue)
            updateValue(newValue, false)
        end,
        Get = function() return value end
    }
end

