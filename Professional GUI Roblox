local Theme = {
    Background = Color3.fromRGB(10, 10, 15),       -- Deep black with slight blue tint
    Secondary = Color3.fromRGB(20, 20, 30),        -- Slightly lighter for contrast
    Tertiary = Color3.fromRGB(30, 30, 40),         -- For elements that need depth
    Accent = Color3.fromRGB(0, 160, 255),          -- Vibrant electric blue
    AccentDark = Color3.fromRGB(0, 120, 200),      -- Darker blue for hover states
    Text = Color3.fromRGB(255, 255, 255),          -- Pure white
    TextMuted = Color3.fromRGB(180, 180, 180),    -- For secondary text
    Success = Color3.fromRGB(80, 255, 120),        -- Optional green success
    Error = Color3.fromRGB(255, 80, 80)            -- Optional red error
}

-- Corner rounding configuration (smooth curved aesthetic)
local CornerRadius = UDim.new(0, 12)  -- 12px rounded corners

-- Animation settings
local AnimationSpeed = 0.2  -- seconds for tweens

-- ================================================================
-- HELPER FUNCTIONS
-- ================================================================

-- Drag functionality (since Roblox deprecated .Draggable)
local function makeDraggable(frame, dragHandle)
    dragHandle = dragHandle or frame
    local dragging = false
    local dragStart = nil
    local startPos = nil
    
    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            
            -- Visual feedback during drag
            local tweenInfo = TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
            local goal = {BackgroundColor3 = Theme.AccentDark}
            TweenService:Create(dragHandle, tweenInfo, goal):Play()
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                    -- Reset color
                    local resetGoal = {BackgroundColor3 = Theme.Secondary}
                    TweenService:Create(dragHandle, tweenInfo, resetGoal):Play()
                end
            end)
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or 
                         input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            local newPosition = UDim2.new(
                startPos.X.Scale, 
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
            
            -- Smooth drag using TweenService
            local tweenInfo = TweenInfo.new(0.05, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
            local goal = {Position = newPosition}
            TweenService:Create(frame, tweenInfo, goal):Play()
        end
    end)
end

-- Tween helper for smooth animations
local function smoothTween(object, properties, duration)
    duration = duration or AnimationSpeed
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local tween = TweenService:Create(object, tweenInfo, properties)
    tween:Play()
    return tween
end

